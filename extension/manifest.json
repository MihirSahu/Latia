{
  "manifest_version": 3,
  "name": "Latia",
  "description": "Ask questions about the current page using your own OpenAI-compatible model endpoint.",
  "version": "0.1.0",
  "permissions": ["activeTab", "scripting", "sidePanel", "storage"],
  "host_permissions": ["http://127.0.0.1:*/*", "http://localhost:*/*"],
  "optional_host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open Latia"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}
